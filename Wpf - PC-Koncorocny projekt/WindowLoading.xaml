<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLoading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix Loading" Height="500" Width="800"
        WindowState="Maximized" WindowStyle="None" Background="Black">

    <Viewbox Stretch="Uniform">
        <Grid Width="800" Height="500">
            <Image x:Name="img" Source="/pictures/ChatGPT Image 22. 2. 2026, 13_08_46.png" 
                   Stretch="UniformToFill" Opacity="0.9">
                <Image.Clip>
                    <RectangleGeometry x:Name="clipRect" Rect="0, 0, 0, 500"/>
                </Image.Clip>
            </Image>

            <StackPanel VerticalAlignment="Bottom" Margin="60">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="KRIONIX CORE INITIALIZATION" Foreground="#00F2FF" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtPercent" Text="0%" Foreground="White" HorizontalAlignment="Right" FontSize="14" FontFamily="Consolas"/>
                </Grid>

                <Grid Height="6">
                    <Rectangle Fill="#22FFFFFF" RadiusX="3" RadiusY="3"/>
                    <Rectangle x:Name="ProgressBarFill" Fill="#00F2FF" HorizontalAlignment="Left" RadiusX="3" RadiusY="3" Width="0">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00F2FF" BlurRadius="15" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </Grid>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>