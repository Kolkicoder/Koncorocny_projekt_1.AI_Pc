<Window x:Class="Wpf___PC_Koncorocny_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix OS" Height="500" Width="800"
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize"
        Background="#050505" UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity"
                             From="0.2" To="0.7" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.05" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.05" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#121225" Offset="1" />
                <GradientStop Color="Black" Offset="0" />
            </RadialGradientBrush>
        </Grid.Background>

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="500">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Ellipse x:Name="LogoGlow" Width="140" Height="140" Fill="#00F2FF" Opacity="0.5">
                            <Ellipse.Effect>
                                <BlurEffect Radius="60"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Canvas Width="100" Height="100">
                            <Path Data="M50,0 L93,25 L93,75 L50,100 L7,75 L7,25 Z" 
                                  Stroke="#00F2FF" StrokeThickness="3" Fill="#11FFFFFF">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="LogoScale" CenterX="50" CenterY="50" />
                                </Path.RenderTransform>
                            </Path>
                            <TextBlock Text="K" Foreground="White" FontSize="42" FontWeight="Bold" 
                                       Canvas.Left="36" Canvas.Top="22" FontFamily="Segoe UI Semibold"/>
                        </Canvas>
                    </Grid>
                    <TextBlock Text="KRIONIX" Foreground="White" FontSize="52" FontWeight="ExtraBold" 
                               HorizontalAlignment="Center" Margin="0,25,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00F2FF" BlurRadius="20" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40" Opacity="0.5">
                    <TextBlock Text="COMMAND: ESC + O TO BOOT" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                    <Rectangle Height="1" Fill="#00F2FF" Margin="0,8,0,0" Width="180"/>
                </StackPanel>
            </Grid>
        </Viewbox>
    </Grid>
</Window>