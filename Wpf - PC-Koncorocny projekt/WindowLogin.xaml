<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf___PC_Koncorocny_projekt"
        mc:Ignorable="d"
        Title="Window-Login" Height="500" Width="800">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF4D00FF" Offset="0"/>
            </RadialGradientBrush>
        </Grid.Background>
        <Button x:Name="SetingButton" HorizontalAlignment="Left" Margin="15,424,0,0" VerticalAlignment="Top" Width="30" Height="30" Click="SetingButton_Click">
            <Image x:Name="SetingImage" Height="30" Source="/pictures/360_F_532772075_m3wMcapw93ZFGWBjs3rCcZG1NJGxeben.jpg" Stretch="Fill" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
        <TextBox HorizontalAlignment="Center" Margin="0,40,0,0" TextWrapping="Wrap" Text="Login:" VerticalAlignment="Top" Width="150" Height="65" FontSize="48">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF7200FF" Offset="0.065"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <TextBox x:Name="UserNameTxt" HorizontalAlignment="Left" Margin="300,131,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="350" Height="36" FontSize="24" TextChanged="UserNameTxt_TextChanged">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF7200FF"/>
                    <GradientStop Color="White" Offset="1"/>
                    <GradientStop Color="#FF821DFF" Offset="0"/>
                    <GradientStop Color="#FF7403FF" Offset="0.015"/>
                    <GradientStop Color="#FF7403FF" Offset="0"/>
                    <GradientStop Color="#FF7200FF" Offset="0"/>
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <Button x:Name="UserButton" Content="Change user" HorizontalAlignment="Center" Margin="0,242,0,0" VerticalAlignment="Top" Width="200" Height="50" FontSize="22">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF7200FF"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Image x:Name="PcButton" HorizontalAlignment="Left" Height="30" Margin="61,355,0,0" VerticalAlignment="Top" Width="29" OpacityMask="White"/>
        <PasswordBox x:Name="PasswordTxt" HorizontalAlignment="Left" Margin="300,172,0,0" VerticalAlignment="Top" Width="350" Height="36" FontSize="24">
            <PasswordBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF7200FF" Offset="0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </PasswordBox.Background>
        </PasswordBox>
        <Label Content="User name:" HorizontalAlignment="Left" Margin="177,131,0,0" VerticalAlignment="Top" Foreground="Black" Width="105" Height="36" FontSize="18">
            <Label.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF7200FF" Offset="0.002"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Label.Background>
        </Label>
        <Label Content="Password:" HorizontalAlignment="Left" Margin="177,172,0,0" VerticalAlignment="Top" Width="105" Height="36" FontSize="18">
            <Label.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF7200FF"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Label.Background>
        </Label>
        <Image x:Name="SetingsButton" Source="/360_F_532772075_m3wMcapw93ZFGWBjs3rCcZG1NJGxeben.jpg" Stretch="Fill" OpacityMask="White" Height="26" Width="26"/>
        <Image Margin="590,355,30,30" Source="/pictures/ChatGPT Image 22. 2. 2026, 13_08_46.png" Stretch="Fill" Height="100"/>
    </Grid>
</Window>
