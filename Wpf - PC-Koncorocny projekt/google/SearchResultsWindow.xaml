<Window x:Class="google.SearchResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Results" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Window.Resources>
        <DataTemplate x:Key="ResultCardTemplate">
            <Border Background="#0DFFFFFF" CornerRadius="16" Margin="12" Padding="16" Width="300" Height="160" BorderThickness="1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00FFFF" Offset="0"/>
                        <GradientStop Color="#D000FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Text="{Binding Snippet}" Foreground="#B0FFFFFF" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Text="{Binding Link}" Foreground="#00FFFF" FontSize="11" TextWrapping="NoWrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ResultsList" ItemTemplate="{StaticResource ResultCardTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </ScrollViewer>
</Window>