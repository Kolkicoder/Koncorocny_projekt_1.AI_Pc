<Window x:Class="Wpf___PC_Koncorocny_projekt.Google_domov"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix One" Height="700" Width="1100" 
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#60FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="15" Padding="{TemplateBinding Padding}" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3000FFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="NeonResultTemplate">
            <Border Background="#0DFFFFFF" CornerRadius="20" Margin="12" Padding="20" Width="320" Height="200" BorderThickness="1.5">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00FFFF" Offset="0"/>
                        <GradientStop Color="#D000FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="25" Opacity="0.5" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Text="{Binding Snippet}" Foreground="#B0FFFFFF" FontSize="13" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    <TextBlock Grid.Row="2" Text="{Binding Link}" Foreground="#00FFFF" FontSize="12" Cursor="Hand" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#020205" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Grid Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" HorizontalAlignment="Center" CornerRadius="22" Padding="3" Background="#15FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="CLASSIC" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="REŽIM INKOGNITO" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="AI ASSISTANT" Style="{StaticResource NavButtonStyle}" Click="Button_Click"/>
                    <!-- Close button (X) -->

                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" x:Name="SearchArea" Margin="0,60,0,20">
                <TextBlock Text="Krionix" FontSize="100" FontWeight="Black" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="45" Opacity="0.4" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Width="700" Height="55" CornerRadius="27" BorderThickness="2" Margin="0,30,0,0" Background="#10FFFFFF">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFF" Offset="0"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Foreground="White" Opacity="0.6" VerticalAlignment="Center" FontSize="18" Margin="0,0,15,0"/>
                        <TextBox x:Name="SearchInput" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" FontSize="18" CaretBrush="PapayaWhip" KeyDown="SearchInput_KeyDown"/>
                        <TextBlock Grid.Column="2" Text="✨" Foreground="#D000FF" VerticalAlignment="Center" FontSize="22"/>
                    </Grid>
                </Border>
            </StackPanel>

            <ListBox Grid.Row="2" x:Name="ResultsDisplay" Background="Transparent" BorderThickness="0" Margin="40,10" 
                     Visibility="Collapsed" ItemTemplate="{StaticResource NeonResultTemplate}"
                     MouseDoubleClick="ResultsDisplay_MouseDoubleClick"
                     PreviewMouseLeftButtonUp="ResultsDisplay_PreviewMouseLeftButtonUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- arrange results in up to 3 columns per row -->
                        <UniformGrid Columns="3" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <!-- corner close button (top-right) -->
            <Button x:Name="BtnCloseGoogle" Content="✖" Width="36" Height="30" Click="BtnCloseGoogle_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" FontSize="14"
                    Background="#16000000" Foreground="White" BorderThickness="0" Padding="0"/>
        </Grid>
    </Grid>
</Window>