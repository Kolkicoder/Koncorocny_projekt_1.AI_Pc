<Window x:Class="Wpf___PC_Koncorocny_projekt.Google_domov"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix One" Height="700" Width="1100" 
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize">

    <Window.Resources>
        <DataTemplate x:Key="NeonResultTemplate">
            <Border Background="#0DFFFFFF" CornerRadius="20" Margin="12" Padding="20" Width="320" Height="200" BorderThickness="1.5">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00FFFF" Offset="0"/>
                        <GradientStop Color="#D000FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="25" Opacity="0.5" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Text="{Binding Snippet}" Foreground="#B0FFFFFF" FontSize="13" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    <TextBlock Grid.Row="2" Text="{Binding Link}" Foreground="#00FFFF" FontSize="12" Cursor="Hand" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#020205" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Grid Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" HorizontalAlignment="Center" Background="#15FFFFFF" CornerRadius="20" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <Button Content="CLASSIC" Background="#3000FFFF" Foreground="White" BorderThickness="0" Padding="20,8" Margin="2"/>
                    <Button Content="INCOGNITO" Background="Transparent" Foreground="#60FFFFFF" BorderThickness="0" Padding="20,8" Margin="2"/>
                    <Button Content="AI ASSISTANT" Background="Transparent" Foreground="#60FFFFFF" BorderThickness="0" Padding="20,8" Margin="2"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" x:Name="SearchArea" Margin="0,60,0,20">
                <TextBlock Text="Krionix" FontSize="100" FontWeight="Black" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#D000FF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="45" Opacity="0.4" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Width="700" Height="55" CornerRadius="27" BorderThickness="2" Margin="0,30,0,0" Background="#10FFFFFF">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFF" Offset="0"/>
                            <GradientStop Color="#D000FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Foreground="White" Opacity="0.6" VerticalAlignment="Center" FontSize="18" Margin="0,0,15,0"/>
                        <TextBox x:Name="SearchInput" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" FontSize="18" CaretBrush="Cyan" KeyDown="SearchInput_KeyDown"/>
                        <TextBlock Grid.Column="2" Text="✨" Foreground="#D000FF" VerticalAlignment="Center" FontSize="22"/>
                    </Grid>
                </Border>
            </StackPanel>

            <ListBox Grid.Row="2" x:Name="ResultsDisplay" Background="Transparent" BorderThickness="0" Margin="40,10" 
                     Visibility="Collapsed" ItemTemplate="{StaticResource NeonResultTemplate}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="30" Orientation="Horizontal" Opacity="0.6">
            <Ellipse Width="10" Height="10" Fill="#00FF88" Margin="0,0,10,0"/>
            <TextBlock Text="SECURE KRIONIX NODE ACTIVE" Foreground="White" FontSize="10" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>