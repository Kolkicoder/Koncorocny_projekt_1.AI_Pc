<Window x:Class="Wpf___PC_Koncorocny_projekt.SearchResultsWindow2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Results" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#05060A">

    <Window.Resources>
        <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00FFFF" Offset="0"/>
            <GradientStop Color="#D000FF" Offset="1"/>
        </LinearGradientBrush>

        <DataTemplate x:Key="ResultCardTemplate">
            <Border Background="#0D0F14" CornerRadius="14" Margin="14" Padding="14" Width="320" Height="180" BorderThickness="1.5">
                <Border.BorderBrush>
                    <StaticResource ResourceKey="CardBorderBrush"/>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="20" Opacity="0.18" ShadowDepth="0"/>
                </Border.Effect>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FFFF" BlurRadius="30" Opacity="0.45" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Row="1" Text="{Binding Snippet}" Foreground="#B0FFFFFF" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0" MaxHeight="72" TextTrimming="WordEllipsis"/>
                    <TextBlock Grid.Row="2" Text="{Binding Link}" Foreground="#66FFFF" FontSize="11" TextWrapping="NoWrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="20">
        <!-- Use a ListBox so items can be selected and double-clicked -->
        <ListBox x:Name="ResultsList" ItemTemplate="{StaticResource ResultCardTemplate}" Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Center" MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </ScrollViewer>
</Window>