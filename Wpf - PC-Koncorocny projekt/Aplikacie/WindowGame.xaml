                Background="White" Foreground="Black" BorderThickness="0" Panel.ZIndex="999"/>
        <Button x:Name="ButtonGame1" Content="" HorizontalAlignment="Left" Margin="100,150,0,0" VerticalAlignment="Top" Height="750" RenderTransformOrigin="-0.404,0.505" Width="750" OpacityMask="Black" Click="ButtonGame1_Click"/>
        <Button x:Name="ButtonGame2" Content="" HorizontalAlignment="Right" Margin="419,150,100,0" VerticalAlignment="Top" Height="750" Width="750" Click="ButtonGame2_Click"/>       
    </Grid>
</Window>
