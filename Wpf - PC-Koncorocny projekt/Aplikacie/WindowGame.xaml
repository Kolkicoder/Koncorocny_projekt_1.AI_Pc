<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf___PC_Koncorocny_projekt"
        mc:Ignorable="d"
        Title="WindowGame" Height="450" Width="800">
    <Grid>
        <Button x:Name="BtnGameClose" Content="✖" Click="BtnGameClose_Click" Padding="0" Width="34" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" FontSize="14"
                Background="#16000000" Foreground="White" BorderThickness="0" Panel.ZIndex="999"/>
        <!-- Game area (placeholder) -->
        <TextBlock Text="GAME RUNNING" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="36"/>
    </Grid>
</Window>
