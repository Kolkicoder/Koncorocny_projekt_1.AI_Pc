<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLoading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wpf___PC_Koncorocny_projekt"
        Title="Krionix Loading" Height="700" Width="1000" WindowState="Maximized" WindowStyle="None" Background="Black">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="1" RadiusY="1">
                <GradientStop Color="#0A0A15" Offset="1" />
                <GradientStop Color="Black" Offset="0" />
            </RadialGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Image Source="/pictures/krionix_logo.png" Stretch="Uniform" Width="380" HorizontalAlignment="Center">
                <Image.Effect>
                    <DropShadowEffect Color="#00F2FF" BlurRadius="60" ShadowDepth="0" Opacity="0.4"/>
                </Image.Effect>
            </Image>

            <TextBlock Text="KRIONIX OS" Foreground="White" FontSize="66" FontWeight="Black" HorizontalAlignment="Center" Margin="0,-25,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00F2FF" BlurRadius="35" ShadowDepth="0" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock x:Name="txtStatus" Text="SYSTEM READY" Foreground="#4400F2FF" FontSize="11" 
                       HorizontalAlignment="Left" Margin="0,70,0,10" FontFamily="Consolas"/>

            <Grid Width="600" Height="6">
                <Rectangle Fill="#11FFFFFF" RadiusX="3" RadiusY="3"/>

                <Rectangle x:Name="ManualProgressBarFill" Width="0" Fill="#00F2FF" RadiusX="3" RadiusY="3" HorizontalAlignment="Left">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00F2FF" BlurRadius="20" ShadowDepth="0"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="0,30,0,0" Height="70">

                <TextBlock x:Name="txtPercent" Text="0%" Foreground="#00F2FF" HorizontalAlignment="Center" FontSize="24" FontWeight="Light" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00F2FF" BlurRadius="10" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel x:Name="FinalLoadingArea" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#00F2FF" FontSize="34" 
                                HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="STARTING GRAPHICAL INTERFACE..." Foreground="#00F2FF" FontSize="11" Margin="0,10,0,0" FontWeight="SemiBold"/>
                </StackPanel>

            </Grid>
        </StackPanel>
    </Grid>
</Window>