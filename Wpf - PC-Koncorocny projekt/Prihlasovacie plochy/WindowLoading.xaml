<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLoading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wpf___PC_Koncorocny_projekt"
        Title="Krionix Loading" Height="700" Width="1000" 
        WindowState="Maximized" WindowStyle="None" Background="#020205">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#020205" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Image Source="/pictures/krionix_logo.png" Stretch="Uniform" Width="320" HorizontalAlignment="Center">
                <Image.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="60" ShadowDepth="0" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <TextBlock Text="KRIONIX OS" FontSize="72" FontWeight="Black" HorizontalAlignment="Center" Margin="0,-15,0,0">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        
                        <GradientStop Color="#00FFFF" Offset="0.5"/>


                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock x:Name="txtStatus" Text="SYSTEM READY" Foreground="#60FFFFFF" FontSize="10" 
                       HorizontalAlignment="Center" Margin="0,80,0,12" FontWeight="Bold"/>

            <Grid Width="500" Height="4">
                <Rectangle Fill="#15FFFFFF" RadiusX="2" RadiusY="2"/>
                <Rectangle x:Name="ManualProgressBarFill" Width="0" RadiusX="2" RadiusY="2" HorizontalAlignment="Left">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFF" Offset="0"/>
                            
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="0,25,0,0" Height="80">
                <TextBlock x:Name="txtPercent" Text="0%" Foreground="White" HorizontalAlignment="Center" FontSize="28" FontWeight="Light" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="12" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel x:Name="FinalLoadingArea" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#D000FF" FontSize="36" 
                                HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#D000FF" BlurRadius="20" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="INITIALIZING GRAPHICAL INTERFACE" Foreground="#00FFFF" FontSize="10" Margin="0,15,0,0" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </StackPanel>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="40" Opacity="0.4">
            
        </StackPanel>
        <TextBox HorizontalAlignment="Left" Margin="-193,-70,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Window>