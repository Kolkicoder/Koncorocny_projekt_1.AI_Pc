<Window x:Class="Wpf___PC_Koncorocny_projekt.Google_domov"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix One" Height="700" Width="1100" 
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                <GradientStop Color="#151515" Offset="0"/>
                <GradientStop Color="#050505" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,30,0,0" 
                Background="#11FFFFFF" CornerRadius="20" Padding="5">
            <StackPanel Orientation="Horizontal">
                <Button Content="CLASSIC" Background="#22FFFFFF" Foreground="White" BorderThickness="0" 
                        Padding="20,8" Margin="2" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="INCOGNITO" Background="Transparent" Foreground="#88FFFFFF" BorderThickness="0" 
                        Padding="20,8" Margin="2" Cursor="Hand"/>
                <Button Content="AI ASSISTANT" Background="Transparent" Foreground="#88FFFFFF" BorderThickness="0" 
                        Padding="20,8" Margin="2" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="25" 
                Width="30" Height="30" CornerRadius="15" Background="#1AFFFFFF" Cursor="Hand">
            <TextBlock Text="×" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Margin="0,-2,0,0"/>
        </Border>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="650">

            <TextBlock Text="Krionix" FontSize="95" FontWeight="Black" HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#00F2FF" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00F2FF" BlurRadius="30" Opacity="0.2" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <Border Background="#15FFFFFF" CornerRadius="25" BorderBrush="#25FFFFFF" BorderThickness="1" 
                    Height="50" Margin="0,30,0,0">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="5,0,15,0" Opacity="0.7"/>

                    <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" 
                             VerticalAlignment="Center" FontSize="15" CaretBrush="White" 
                             Text="Hľadať v systéme..." Opacity="0.5" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="✨" Foreground="#BB86FC" FontSize="18" VerticalAlignment="Center" Margin="10,0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0" Opacity="0.6"/>

        </StackPanel>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="25" Orientation="Horizontal" Opacity="0.4">
            <Ellipse Width="8" Height="8" Fill="#00FF00" Margin="0,0,8,0"/>
            <TextBlock Text="SECURE CONNECTION ESTABLISHED" Foreground="White" FontSize="9" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>