<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLogin"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Krionix Auth" Height="500" Width="800"
       WindowState="Maximized" WindowStyle="None" Background="#020205">

    <Window.Resources>
        <Storyboard x:Key="RotateLoading">
            <DoubleAnimation Storyboard.TargetName="LoadingRotateTransform" 
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1" 
                             RepeatBehavior="Forever" />
        </Storyboard>

        <Style x:Key="PowerMenuStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2000FFFF"/>
                    <Setter Property="Foreground" Value="#00FFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="800" Height="500">
            <Grid x:Name="MainContentGrid">
                <Grid.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#020205" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>

                <Border x:Name="LoginBox" Width="380" VerticalAlignment="Center" Background="#0DFFFFFF" CornerRadius="25" BorderThickness="1.5" Padding="35">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00FFFF" Offset="0"/>
                            <GradientStop Color="#D000FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="30" Opacity="0.2" ShadowDepth="0"/>
                    </Border.Effect>

                    <Grid>
                        <StackPanel x:Name="LoginControls" Visibility="Visible">
                            <TextBlock Text="KRIONIX" FontSize="32" FontWeight="Black" HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="#00FFFF" Offset="0.5"/>
                                        <GradientStop Color="#D000FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <Rectangle Height="2" Width="60" Margin="0,10,0,35">
                                <Rectangle.Fill>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#00FFFF" Offset="0"/>
                                        <GradientStop Color="#D000FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <TextBlock Text="IDENTIFICATION / USERNAME" Foreground="#60FFFFFF" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border CornerRadius="10" Background="#15000000" BorderThickness="1" BorderBrush="#30FFFFFF" Margin="0,0,0,20">
                                <TextBox x:Name="UserNameTxt" Background="Transparent" Foreground="White" BorderThickness="0" Height="38" VerticalContentAlignment="Center" Padding="12,0" CaretBrush="#00FFFF" TextChanged="UserNameTxt_TextChanged"/>
                            </Border>

                            <TextBlock Text="SECURITY KEY / PASSWORD" Foreground="#60FFFFFF" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border CornerRadius="10" Background="#15000000" BorderThickness="1" BorderBrush="#30FFFFFF" Margin="0,0,0,30">
                                <PasswordBox x:Name="PasswordTxt" Background="Transparent" Foreground="White" BorderThickness="0" Height="38" VerticalContentAlignment="Center" Padding="12,0" CaretBrush="#D000FF"/>
                            </Border>

                            <Button x:Name="UserButton" Click="UserButton_Click" Height="45" Cursor="Hand" BorderThickness="0" Margin="0,0,0,15">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder" Background="#00FFFF" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="#D000FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="INITIALIZE LOGIN" FontWeight="Bold" Foreground="Black" FontSize="13"/>
                            </Button>

                            <Button x:Name="ChangeUserButton" Content="SWITCH OPERATOR" Background="Transparent" Foreground="#60FFFFFF" BorderThickness="0" FontSize="10" Cursor="Hand" Click="ChangeUserButton_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="LoadingOverlay" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="60" Height="60">
                                <Ellipse Stroke="#10FFFFFF" StrokeThickness="4"/>
                                <Ellipse Stroke="#00FFFF" StrokeThickness="4" StrokeDashArray="3 1" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00FFFF" BlurRadius="15" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="LoadingRotateTransform" Angle="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock Text="AUTHORIZING..." Foreground="#00FFFF" Margin="0,20,0,0" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button x:Name="SetingButton" Click="SetingButton_Click" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30" Width="50" Height="50" Background="#15FFFFFF" BorderThickness="1" BorderBrush="#30FFFFFF">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="⚙" Foreground="White" FontSize="24" HorizontalAlignment="Center"/>
                </Button>

                <Border x:Name="PowerMenuOverlay" Visibility="Collapsed" Background="#F2020205" CornerRadius="15" Width="180" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="30,0,0,90" BorderBrush="#00FFFF" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel Margin="8">
                        <Button Content="LOCK" Click="Lock_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="SLEEP" Click="Sleep_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="SHUTDOWN" Click="Shutdown_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="RESTART" Click="Restart_Click" Style="{StaticResource PowerMenuStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="NewUserModal" Visibility="Collapsed">
                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.8"/>
                </Grid.Background>
                <Border Width="320" Height="240" Background="#1A1A2E" CornerRadius="20" BorderBrush="#D000FF" BorderThickness="1.5" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#D000FF" BlurRadius="30" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel Margin="30">
                        <TextBlock Text="NEW SESSION" Foreground="#00FFFF" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                        <Border CornerRadius="8" Background="#10FFFFFF" BorderThickness="0,0,0,1" BorderBrush="#00FFFF">
                            <TextBox Background="Transparent" Foreground="White" BorderThickness="0" Height="38" VerticalContentAlignment="Center" Padding="10,0" CaretBrush="White"/>
                        </Border>
                        <UniformGrid Columns="2" Margin="0,35,0,0" Height="45">
                            <Button Content="CANCEL" Click="CloseModal_Click" Background="Transparent" Foreground="#60FFFFFF" BorderThickness="0" Cursor="Hand"/>
                            <Button Click="CloseModal_Click" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#D000FF" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="PROCEED" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</Window>