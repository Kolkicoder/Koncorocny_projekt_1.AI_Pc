<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowLogin"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Krionix Auth" Height="500" Width="800"
       WindowState="Maximized" WindowStyle="None" Background="#080808">

    <Window.Resources>
        <Storyboard x:Key="RotateLoading">
            <DoubleAnimation Storyboard.TargetName="LoadingRotateTransform" 
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1" 
                             RepeatBehavior="Forever" />
        </Storyboard>

        <Style x:Key="PowerMenuStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3300F2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="800" Height="500">
            <Grid x:Name="MainContentGrid">
                <Grid.Background>
                    <RadialGradientBrush Center="0.5,0.4" RadiusX="1" RadiusY="1">
                        <GradientStop Color="#1A0044" Offset="0"/>
                        <GradientStop Color="Black" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>

                <Border x:Name="LoginBox" Width="380" VerticalAlignment="Center" Background="#15FFFFFF" CornerRadius="20" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="30">
                    <Grid>
                        <StackPanel x:Name="LoginControls" Visibility="Visible">
                            <TextBlock Text="KRIONIX" Foreground="White" FontSize="28" FontWeight="Black" HorizontalAlignment="Center"/>
                            <Rectangle Height="2" Fill="#00F2FF" Width="50" Margin="0,10,0,30"/>

                            <TextBlock Text="USER NAME" Foreground="#88FFFFFF" FontSize="9" Margin="0,0,0,5"/>
                            <TextBox x:Name="UserNameTxt" Background="#22000000" Foreground="White" BorderBrush="#44FFFFFF" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,20"/>

                            <TextBlock Text="PASSWORD" Foreground="#88FFFFFF" FontSize="9" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="PasswordTxt" Background="#22000000" Foreground="White" BorderBrush="#44FFFFFF" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,25"/>

                            <Button x:Name="UserButton" Content="LOGIN" Click="UserButton_Click" Height="45" Background="#00F2FF" Foreground="Black" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="CHANGE USER" Click="UserButton_Click_1" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel x:Name="LoadingOverlay" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="60" Height="60">
                                <Ellipse Stroke="#22FFFFFF" StrokeThickness="5"/>
                                <Ellipse Stroke="#00F2FF" StrokeThickness="5" StrokeDashArray="2 1" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="LoadingRotateTransform" Angle="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock Text="AUTHORIZING..." Foreground="#00F2FF" Margin="0,20,0,0" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button x:Name="SetingButton" Click="SetingButton_Click" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30" Width="45" Height="45" Background="#22FFFFFF" BorderThickness="0">
                    <TextBlock Text="⚙" Foreground="White" FontSize="24" HorizontalAlignment="Center"/>
                </Button>

                <Border x:Name="PowerMenuOverlay" Visibility="Collapsed" Background="#F2111111" CornerRadius="12" Width="180" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="30,0,0,85" BorderBrush="#00F2FF" BorderThickness="1">
                    <StackPanel Margin="5">
                        <Button Content="LOCK" Click="Lock_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="SLEEP" Click="Sleep_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="SHUTDOWN" Click="Shutdown_Click" Style="{StaticResource PowerMenuStyle}"/>
                        <Button Content="RESTART" Click="Restart_Click" Style="{StaticResource PowerMenuStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="NewUserModal" Visibility="Collapsed">
                <Rectangle Fill="#CC000000" MouseLeftButtonDown="CloseModal_Click_1"/>
                <Border Width="300" Height="220" Background="#111111" CornerRadius="15" BorderBrush="#00F2FF" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Margin="25">
                        <TextBlock Text="NEW SESSION" Foreground="#00F2FF" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBox Background="#22FFFFFF" Foreground="White" BorderThickness="0,0,0,1" Height="35" VerticalContentAlignment="Center" Padding="10,0"/>
                        <UniformGrid Columns="2" Margin="0,30,0,0" Height="40">
                            <Button Content="CANCEL" Click="CloseModal_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
                            <Button Content="PROCEED" Background="#00F2FF" Foreground="Black" FontWeight="Bold"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</Window>