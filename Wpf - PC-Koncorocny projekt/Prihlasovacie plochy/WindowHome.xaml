<Window x:Class="Wpf___PC_Koncorocny_projekt.WindowHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix Desktop" Height="600" Width="1000" WindowState="Maximized" WindowStyle="None">

    <Grid Background="Black">
        <Image x:Name="HomeTapeta" Source="/pictures/ChatGPT Image 4. 3. 2026, 12_50_39.png" Stretch="UniformToFill">
            <Image.Effect>
                <BlurEffect Radius="15"/>
            </Image.Effect>
        </Image>

        <Rectangle Fill="#66000000"/>

        <Grid>
            <Border VerticalAlignment="Top" Height="40" Background="#44000000" BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M10,0 L18.6,5 L18.6,15 L10,20 L1.4,15 L1.4,5 Z" Fill="#00F2FF" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="KRIONIX OS" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="SYSTEM SECURED" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#00F2FF" FontSize="9"/>
                </Grid>
            </Border>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="W E L C O M E" Foreground="#AAFFFFFF" FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="KRIONIX" Foreground="White" FontSize="86" FontWeight="Black" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00F2FF" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>

                <UniformGrid Columns="2" Margin="0,40,0,0" Width="420">
                    <Button x:Name="BtnGoogle" Height="65" Margin="10" Background="#22FFFFFF" BorderBrush="#00F2FF" BorderThickness="1" Foreground="White" Cursor="Hand" Click="BtnGoogle_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="G" FontWeight="Bold" FontSize="22" Margin="0,0,12,0" Foreground="#00F2FF"/>
                            <TextBlock Text="GOOGLE CHROME" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPexeso" Height="65" Margin="10" Background="#22FFFFFF" BorderBrush="#00F2FF" BorderThickness="1" Foreground="White" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎮" FontSize="22" Margin="0,0,12,0"/>
                            <TextBlock Text="PEXESO HRA" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>

            <Border VerticalAlignment="Bottom" Height="55" Background="#E5101010" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0">
                <Grid Margin="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0.9">
                        <TextBlock Text="☁️" FontSize="20" VerticalAlignment="Center" Margin="5,0,8,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="7°C" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="Slabý déšť" Foreground="#AAFFFFFF" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Margin="5,0" Cursor="Hand">
                            <Rectangle Width="28" Height="28" Fill="#00A4EF" RadiusX="3" RadiusY="3"/>
                            <Path Data="M2,2 H10 V10 H2 Z M12,2 H20 V10 H12 Z M2,12 H10 V20 H2 Z M12,12 H20 V20 H12 Z" 
                                  Fill="White" Stretch="Uniform" Margin="6"/>
                        </Grid>

                        <Border Background="#22FFFFFF" CornerRadius="15" Width="180" Height="32" Margin="12,0">
                            <StackPanel Orientation="Horizontal" Margin="12,0">
                                <TextBlock Text="🔍" Foreground="#99FFFFFF" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Hľadať v systéme..." Foreground="#99FFFFFF" VerticalAlignment="Center" FontSize="11" Margin="10,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="📁" FontSize="24" Margin="10,0" VerticalAlignment="Center" Cursor="Hand"/>
                        <TextBlock Text="🌐" FontSize="24" Margin="10,0" VerticalAlignment="Center" Cursor="Hand"/>
                        <TextBlock Text="🎵" FontSize="24" Margin="10,0" VerticalAlignment="Center" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0" Opacity="0.8">
                            <TextBlock Text="ENG" Foreground="White" FontSize="11" Margin="10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="📶" Foreground="White" FontSize="14" Margin="6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="🔊" Foreground="White" FontSize="14" Margin="6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="🔋 99%" Foreground="White" FontSize="11" Margin="6,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" MinWidth="70">
                            <TextBlock x:Name="TxtTime" Text="19:00" Foreground="White" FontSize="12" HorizontalAlignment="Right" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDate" Text="1. 4. 2026" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>