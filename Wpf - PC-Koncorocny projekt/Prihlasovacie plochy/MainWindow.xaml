<Window x:Class="Wpf___PC_Koncorocny_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Krionix OS" Height="600" Width="1000" 
        WindowState="Maximized" WindowStyle="None" Background="Black">

    <Grid x:Name="MainGrid">

        <Button x:Name="BtnPower" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Margin="0,0,40,40" Width="45" Height="45" Cursor="Hand"
                Visibility="Visible" Click="BtnPower_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Fill="#00F2FF" Opacity="0.2">
                            <Ellipse.Effect>
                                <BlurEffect Radius="15"/>
                            </Ellipse.Effect>
                        </Ellipse>

                        <Ellipse Stroke="#00F2FF" StrokeThickness="1.5" Fill="#05FFFFFF"/>

                        <Canvas Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M22.5,10 V23 M16.5,16.5 A10,10 0 1,0 28.5,16.5" 
                                  Stroke="#00F2FF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Canvas.Left="0" Canvas.Top="0"/>
                        </Canvas>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>